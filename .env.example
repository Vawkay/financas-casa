# ----------------------------------------------------------------------------
# Finanças da Casa — variáveis de ambiente
# Copie para .env.local e preencha com os valores do seu projeto Supabase.
# ----------------------------------------------------------------------------

# Supabase → Project Settings → API Keys → "Publishable and secret API keys"
# Use a PUBLISHABLE key (sb_publishable_...). A Secret key NÃO é usada por este app.
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Supabase → Project Settings → Database → Connection string → "Transaction pooler"
# (porta 6543). Usada pelo Drizzle (migrations e queries server-side).
DATABASE_URL="postgresql://postgres.SEU-PROJETO:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres"

# E-mails autorizados a entrar (separados por vírgula). App single-user.
ALLOWED_EMAILS="felipe.vkw@hotmail.com"

# Categorização por IA na importação (Fase 2). Opcional — sem chave, o app usa
# só as regras. Chave da API do Google Gemini (aistudio.google.com/apikey).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"
